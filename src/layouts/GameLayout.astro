---
import HarborWidget from "../harbor/HarborWidget";
import manifest from "../generated/pond-manifest.json";
import "../styles/site.css";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Harbor is a portable fishing widget with Astro acting as a demo host.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <meta content={description} name="description" />
    <title>{title} | Harbor</title>
  </head>
  <body class="game-body">
    <script is:inline>
      document.documentElement.dataset.js = "ready";
    </script>
    <HarborWidget client:load manifest={manifest} mode="standalone" title={title} />
  </body>
</html>
