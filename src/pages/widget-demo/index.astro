---
import WidgetDemoHost from "../../harbor/WidgetDemoHost";
import manifest from "../../generated/pond-manifest.json";
const pageTitle = "Harbor Widget Demo";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <meta
      content="A minimal Astro host that mounts the Harbor fishing widget with host-provided artifacts."
      name="description"
    />
    <title>{pageTitle} | Harbor</title>
    <style>
      :root {
        color: #16324a;
        font-family: "Avenir Next", "Trebuchet MS", "Segoe UI", sans-serif;
      }

      body {
        margin: 0;
        min-height: 100vh;
        background:
          radial-gradient(circle at top left, rgba(245, 158, 11, 0.18), transparent 24rem),
          radial-gradient(circle at top right, rgba(30, 144, 167, 0.22), transparent 24rem),
          linear-gradient(180deg, #fff8ed 0%, #f3ebda 100%);
      }

      main {
        margin: 0 auto;
        max-width: 68rem;
        padding: 2rem 1rem 3rem;
      }

      main :global(.harbor-widget) {
        min-height: min(46rem, 88vh);
      }
    </style>
  </head>
  <body>
    <main>
      <WidgetDemoHost client:load manifest={manifest} />
    </main>
  </body>
</html>
