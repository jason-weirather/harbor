---
import manifest from "../../generated/pond-manifest.json";
import PondApp from "./PondApp";
import PondFallback from "./PondFallback.astro";

interface Props {
  variant?: "sidecar" | "room";
}

const { variant = "sidecar" } = Astro.props;
const title =
  variant === "room" ? "Clubhouse Pond Room" : "Clubhouse Pond Sidecar";
const subtitle =
  variant === "room"
    ? "A dedicated room for casting, catching, and opening artifact pages."
    : "A companion toy that sits beside the article and keeps the writing central.";
---

<section class:list={["pond-shell", variant === "room" && "pond-shell--room"]}>
  <header class="pond-shell__header">
    <p class="hero-kicker">Playable companion</p>
    <h2>{title}</h2>
    <p>{subtitle}</p>
    <div class="pond-shell__stats">
      <span>{manifest.fish.length} fish templates</span>
      <span>{manifest.artifacts.length} artifacts</span>
      <span>
        <a href="/pond/manifest.json">manifest.json</a>
      </span>
    </div>
  </header>
  <PondApp client:load manifest={manifest} variant={variant} />
  <PondFallback />
</section>

