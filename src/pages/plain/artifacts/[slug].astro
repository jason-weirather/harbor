---
import { getCollection, render } from "astro:content";
import SiteLayout from "../../../layouts/SiteLayout.astro";

export async function getStaticPaths() {
  const artifacts = await getCollection("artifacts");

  return artifacts.map((artifact) => ({
    params: { slug: artifact.id },
    props: { artifact },
  }));
}

const { artifact } = Astro.props;
const { Content } = await render(artifact);
---

<SiteLayout title={`${artifact.data.title} Plain`} description={artifact.data.summary}>
  <article class="prose artifact-prose">
    <header class="page-hero page-hero--compact">
      <p class="hero-kicker">Plain artifact page</p>
      <h1>{artifact.data.title}</h1>
      <p class="hero-copy">{artifact.data.summary}</p>
      <div class="article-meta">
        <span>{artifact.data.authorName}</span>
        {artifact.data.disclosure && <span>{artifact.data.disclosure}</span>}
        <span>
          <a href={`/artifacts/${artifact.id}/`}>Back to fishing world</a>
        </span>
      </div>
    </header>
    <Content />
    <p>
      <a href="/plain/artifacts/">Browse all plain artifacts</a>
    </p>
  </article>
</SiteLayout>
