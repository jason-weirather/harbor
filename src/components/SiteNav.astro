---
const pathname = Astro.url.pathname;
interface Props {
  variant?: "default" | "world";
}

const { variant = "default" } = Astro.props;

const links = [
  { href: "/", label: "Home" },
  { href: "/posts/a-quiet-cast-into-harbor/", label: "Library" },
  { href: "/rooms/pond/", label: "Pond Demo" },
  { href: "/artifacts/", label: "Artifacts" },
];
---

<nav class:list={["site-nav", variant === "world" && "site-nav--world"]} aria-label="Primary">
  <a class="site-nav__brand" href="/">
    <span class="site-nav__eyebrow">Harbor</span>
    <strong>Fishing Widget Demo</strong>
  </a>
  <p class="site-nav__intro">
    {
      variant === "world"
        ? "A standalone fishing widget first, with reading links and host-friendly artifact surfaces layered around it."
        : "A portable fishing widget with demo hosts, durable artifact links, and just enough page chrome to explain it."
    }
  </p>
  <div class="site-nav__links">
    {
      links.map((link) => (
        <a
          class:list={["site-nav__link", pathname === link.href && "is-active"]}
          href={link.href}
        >
          {link.label}
        </a>
      ))
    }
  </div>
  <div class="site-nav__note">
    {
      variant === "world" ? (
        <>
          <p>Standalone mode</p>
          <strong>The widget owns the page</strong>
          <span>Panels float above the scene and keep interaction scoped to the demo.</span>
        </>
      ) : (
        <>
          <p>Widget modes</p>
          <strong>standalone / embedded / background</strong>
          <span>One widget surface, multiple host contexts.</span>
        </>
      )
    }
  </div>
</nav>
